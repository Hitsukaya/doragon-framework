#!/usr/bin/env bash
set -euo pipefail

DORAGON="${DORAGON:-/usr/libexec/doragon}"

source "${DORAGON}/core/bootstrap"

doragon_verify_core || exit 1

doragon_verify_modules || exit 1

doragon_load_config || true

doragon_print_header

ensure_root_if_needed() {
  local primary="$1"
  shift
  case "$primary" in
    status|report|diagnose|gdpr)
      if [[ ${EUID:-$(id -u)} -ne 0 ]]; then
        if sudo -n true 2>/dev/null; then
          exec sudo "$0" "$primary" "$@"
        else
          info "Doragon requires elevated privileges for full diagnostics."
          info "Run: sudo doragon $primary $*"
          exit 2
        fi
      fi
      ;;
  esac
}

doragon_call_cli "$@"
